# Copy this file to .env and fill in values (never commit .env)

ENVIRONMENT=development
LOG_LEVEL=info

# --- OpenRouter (recommended: one key for many models; OpenAI-compatible API) ---
# Create a key: https://openrouter.ai/keys
# Model list: https://openrouter.ai/models (format: provider/model, e.g. openai/gpt-4o-mini)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional — site URL for OpenRouter rankings dashboard:
# OPENROUTER_HTTP_REFERER=https://localhost

# --- Google AI Studio (Gemini) — optional if you use OpenRouter ---
# Get a key: https://aistudio.google.com/apikey
# You can use either variable name:
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Model name (text RAG + questions); examples: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash
GEMINI_MODEL=gemini-1.5-flash

# --- OpenAI (optional direct API; used if OpenRouter + Gemini are not set or fail) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq / Supabase / Redis / AWS / LlamaParse — optional
GROQ_API_KEY=
SUPABASE_URL=
SUPABASE_KEY=
REDIS_URL=redis://localhost:6379
LLAMAPARSE_API_KEY=

SECRET_KEY=change-me-in-production

CHUNK_SIZE=512
CHUNK_OVERLAP=128
MIN_CONFIDENCE_THRESHOLD=0.7
DOCMIND_DEVICE=auto
DOCMIND_SKIP_NLI=
